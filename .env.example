# Skills House 环境变量配置

# JWT Secret（生产环境请修改为随机字符串）
JWT_SECRET=skills-house-secret-key-change-in-production

# 服务器端口
PORT=3100

# COS 对象存储配置（可选）
# 如果不配置，将使用本地文件系统存储

# COS SecretId 和 SecretKey（从腾讯云控制台获取）
COS_SECRET_ID=
COS_SECRET_KEY=

# COS Bucket 名称（格式：bucket-appid）
COS_BUCKET=skills-house-1234567890

# COS Region（地域）
# 可选值：ap-beijing, ap-shanghai, ap-guangzhou, ap-chengdu 等
COS_REGION=ap-guangzhou

# CDN 加速域名（可选，如果配置了 CDN）
COS_CDN=

# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入实际的 COS 配置信息
# 3. 确保 .env 文件不被提交到 Git（已在 .gitignore 中）
#
# 获取 COS 密钥：
# https://console.cloud.tencent.com/cam/capi
#
# 创建 COS Bucket：
# https://console.cloud.tencent.com/cos5/bucket
